# ---------------------------------------------------------------------------
# Environment variables for the Work With Me / checkout system.
# Copy to .env.local for local dev, and set these in the Vercel dashboard.
# NEVER commit real keys. STRIPE_SECRET_KEY is server-only — it is only read
# in app/api/checkout/route.ts and app/commercial/success/page.tsx and is never
# sent to the browser.
# ---------------------------------------------------------------------------

# Stripe — required for the "Book a Consultation" checkout to work.
STRIPE_SECRET_KEY=sk_live_or_test_xxx

# Optional: absolute site URL used for Checkout success/cancel redirects.
# Falls back to the request origin if unset.
NEXT_PUBLIC_SITE_URL=https://camille-buzuno-portfolio.vercel.app

# Project-inquiry email delivery via Resend (https://resend.com).
# Optional: the inquiry form works without these, but submissions are only
# written to the server logs until all three are set (and the domain verified).
RESEND_API_KEY=re_xxx
INQUIRY_TO_EMAIL=russallks.off@gmail.com
INQUIRY_FROM_EMAIL=Camille Buzuno <inquiries@your-verified-domain.com>
